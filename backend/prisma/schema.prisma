generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  recruiter
}

model User {
  id          Int           @id @default(autoincrement())
  name        String
  email       String        @unique
  password    String
  role        UserRole      @default(recruiter)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  notes       CandidateNote[]
  activityLog ActivityLog[]
  talentSearches TalentSearch[]
  retentionActions RetentionAction[]
}

model RecruitmentStage {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  orderIndex Int
  candidates Candidate[]
}

model Candidate {
  id               Int            @id @default(autoincrement())
  name             String
  email            String?
  phone            String?
  linkedinUrl      String?
  githubUrl        String?
  currentCompany   String?
  currentRole      String?
  skills           String[]
  experienceYears  Int
  education        String?
  location         String?
  resumeUrl        String?
  stageId          Int
  summary          String?
  openToWork       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  stage            RecruitmentStage @relation(fields: [stageId], references: [id])
  notes            CandidateNote[]
  activityLog      ActivityLog[]
  talentMatches    TalentSearchMatch[]

  @@index([skills], type: Gin)
  @@index([experienceYears])
  @@index([location])
}

model TalentSearch {
  id                     Int                 @id @default(autoincrement())
  recruiterId            Int
  role                   String
  experienceRequired     String?
  location               String?
  skills                 String[]
  industry               String?
  additionalRequirements String?
  createdAt              DateTime            @default(now())
  recruiter              User                @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  matches                TalentSearchMatch[]

  @@index([recruiterId])
  @@index([createdAt])
}

model TalentSearchMatch {
  id              Int         @id @default(autoincrement())
  talentSearchId  Int
  candidateId     Int
  matchScore      Int
  summary         String
  strengths       String[]
  recommendedRole String
  roleFit         String?
  shortlisted     Boolean     @default(false)
  exported        Boolean     @default(false)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  talentSearch    TalentSearch @relation(fields: [talentSearchId], references: [id], onDelete: Cascade)
  candidate       Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([talentSearchId, candidateId])
  @@index([candidateId])
  @@index([matchScore])
}

model CandidateNote {
  id          Int       @id @default(autoincrement())
  candidateId Int
  userId      Int
  note        String
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id          Int       @id @default(autoincrement())
  action      String
  metadata    Json?
  userId      Int?
  candidateId Int?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
}

model Employee {
  id               Int       @id @default(autoincrement())
  employeeCode     String?   @unique
  name             String
  email            String    @unique
  linkedinUsername String?
  linkedinUrl      String
  githubUrl        String?
  department       String?
  currentRole      String?
  salary           Float?
  experience       Float?
  joinDate         DateTime?
  performanceScore Float?
  engagementScore  Float?
  attendanceScore  Float?
  managerConcern   Boolean   @default(false)
  marketSalary     Float?
  resumeUpdatedAt  DateTime?
  linkedinUpdatedAt DateTime?
  riskScore        Float?
  riskLevel        String?
  riskReason       String?
  signalsDetected  String[]
  platformsFlagged String[]
  platformProfiles Json?
  riskBreakdown    Json?
  recommendation   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  signals          EmployeeSignal[]
  attritionRisk    AttritionRisk?
  retentionActions RetentionAction[]
}

model EmployeeSignal {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  signalType   String
  signalValue  String
  detectedDate DateTime @default(now())
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([signalType])
  @@index([detectedDate])
}

model AttritionRisk {
  id             Int      @id @default(autoincrement())
  employeeId     Int      @unique
  riskScore      Int
  riskLevel      String
  reasons        String[]
  aiExplanation  String?
  recommendation String?
  lastCalculated DateTime @updatedAt
  createdAt      DateTime @default(now())
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([riskLevel])
  @@index([riskScore])
}

model RetentionAction {
  id         Int      @id @default(autoincrement())
  employeeId Int
  hrId       Int?
  actionType String
  notes      String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  hr         User?    @relation(fields: [hrId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([hrId])
  @@index([date])
}

model JobRole {
  id                 Int      @id @default(autoincrement())
  title              String
  requiredSkills     String[]
  experienceRequired Int      @default(0)
  description        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([requiredSkills], type: Gin)
}

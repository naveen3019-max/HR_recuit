# Server
PORT=5000
NODE_ENV=production

# Database (Railway provides this automatically)
DATABASE_URL="postgresql://postgres:password@host:5432/railway"

# Auth
JWT_SECRET="generate-a-strong-random-secret"
JWT_EXPIRES_IN="1d"

# Frontend URL (your Vercel URL, comma-separated if multiple)
FRONTEND_URL="https://your-app.vercel.app"

# Chrome extension origins (comma-separated)
EXTENSION_ORIGINS="chrome-extension://your_extension_id"

# Shared secret for extension -> /api/linkedin/pending-search, /api/linkedin/analyze-profile, /api/linkedin/search-complete
LINKEDIN_EXTENSION_API_KEY="generate-a-strong-random-secret"

# Gemini AI
LLM_API_URL="https://generativelanguage.googleapis.com/v1beta/models"
LLM_API_KEY="your_gemini_api_key"
LLM_MODEL="gemini-2.5-flash"

# GitHub (for candidate analysis)
GITHUB_TOKEN="your_github_personal_access_token"

# LinkedIn OAuth (optional)
LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"
LINKEDIN_REDIRECT_URI="https://your-backend.up.railway.app/api/linkedin/callback"
LINKEDIN_API_BASE_URL="https://api.linkedin.com/v2"
